{
  "manifest_version": 3,
  "name": "Rate My AU Professors",
  "version": "1.0",
  "description": "Displays Rate My Professors ratings directly inside AU Eagle Service.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.american.edu/*",
    "https://www.ratemyprofessors.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AU Rate My Professors Integration",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://eagleservice.american.edu/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}